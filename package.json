{
  "name": "korina",
  "version": "0.9.28",
  "description": "korina — Opencode 的心跳底座（心跳调度 + 注入 + 续命 + 多会话 + TTS + 语音输入），可构建 agent 工作流生态",
  "type": "module",
  "main": "src/main.mjs",
  "bin": {
    "korina": "src/main.mjs",
    "korina-tail": "watchdog/heartbeat-tail.mjs"
  },
  "scripts": {
    "start": "node src/main.mjs",
    "tail": "node watchdog/heartbeat-tail.mjs --follow",
    "tail:once": "node watchdog/heartbeat-tail.mjs --no-follow --lines 30",
    "mcp": "python mcp/korina_mcp_server.py",
    "test": "node tests/test-e2e.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chokidar": "^4.0.3"
  },
  "keywords": [
    "opencode",
    "ai-agent",
    "heartbeat",
    "korina",
    "timer-tasks",
    "mcp",
    "multi-session",
    "long-running",
    "tts",
    "voice-input",
    "whisper",
    "desktop-agent"
  ],
  "author": "Koko & 冬蕴雪",
  "license": "MIT",
  "homepage": "https://github.com/dyx3364738934-dev/The-Opencode-Heartbeat",
  "repository": {
    "type": "git",
    "url": "https://github.com/dyx3364738934-dev/The-Opencode-Heartbeat.git"
  },
  "bugs": {
    "url": "https://github.com/dyx3364738934-dev/The-Opencode-Heartbeat/issues"
  }
}
